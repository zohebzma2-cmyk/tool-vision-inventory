{
  "appId": "app.toolvision.inventory",
  "appName": "Tool Vision",
  "webDir": "dist",
  "server": {
    "url": "https://tool-vision.pages.dev",
    "cleartext": false
  },
  "ios": {
    "contentInset": "never",
    "backgroundColor": "#1b1f27"
  },
  "plugins": {
    "Camera": {
      "permissions": [
        "camera",
        "photos"
      ]
    },
    "Keyboard": {
      "resize": "native",
      "resizeOnFullScreen": true
    }
  },
  "backgroundColor": "#1b1f27"
}