# Copy to .env on the box and fill in.
# Model: qwen2.5vl:7b (best accuracy, needs ~8GB RAM/VRAM) or qwen2.5vl:3b (lighter/faster).
VISION_MODEL=qwen2.5vl:7b
# Comma-separated frontend origins allowed to call this endpoint.
ALLOWED_ORIGINS=https://tool-vision.pages.dev,https://tools.zohebalvi.com
# Your Supabase project so the endpoint only serves signed-in users of your app.
SUPABASE_URL=https://tgcrsgheezmteravjbwe.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
