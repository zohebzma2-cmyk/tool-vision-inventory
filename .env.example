# Copy to .env and fill in. All VITE_* vars are exposed to the browser.

# Supabase project (free tier). Get these from your Supabase project settings > API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Self-hosted open-source vision service (runs on the Mac mini via Ollama + a small adapter).
# Public HTTPS URL exposed through the Cloudflare Tunnel, e.g. https://vision.yourdomain.com
VITE_VISION_API_URL=

# Base URL of this web app (used for QR deep-links). Use your public tunnel URL in production.
VITE_PUBLIC_BASE_URL=http://localhost:8080
